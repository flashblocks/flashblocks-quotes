{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "flashblocks/flashblocks-quotes",
	"version": "0.1.0",
	"title": "Flashblocks Quote",
	"category": "text",
	"icon": "format-quote",
	"description": "Displays a quote with author name, role, and photo. Works standalone or inside a Query Loop.",
	"keywords": [ "quote", "testimonial", "blockquote" ],
	"textdomain": "flashblocks-quotes",
	"attributes": {
		"selectedPostId": {
			"type": "integer",
			"default": 0
		}
	},
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": {
			"background": true,
			"text": true,
			"link": false
		},
		"spacing": {
			"padding": true,
			"margin": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"styles": [
		{
			"name": "default",
			"label": "Default",
			"isDefault": true
		},
		{
			"name": "card",
			"label": "Card"
		},
		{
			"name": "minimal",
			"label": "Minimal"
		}
	],
	"example": {
		"attributes": {
			"selectedPostId": 0
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
